// LVS Prisma Schema
// Database: PostgreSQL 15

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// 사용자 및 인증
// ========================================

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  password         String
  name             String
  role             UserRole    @default(USER)
  status           UserStatus  @default(ACTIVE)
  phone            String?
  company          String?
  suspendedAt      DateTime?
  suspendedReason  String?
  deletedAt        DateTime?
  signupIp         String?
  signupUserAgent  String?
  suspicionFlags   String[]    @default([])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  auditLogs        UserAuditLog[] @relation("UserAuditTarget")
  auditActions     UserAuditLog[] @relation("UserAuditActor")

  @@index([status])
  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model UserAuditLog {
  id             String   @id @default(cuid())
  userId         String
  adminId        String?
  action         String
  previousStatus UserStatus?
  newStatus      UserStatus?
  reason         String?
  metadata       Json?
  createdAt      DateTime @default(now())

  user           User     @relation("UserAuditTarget", fields: [userId], references: [id], onDelete: Cascade)
  admin          User?    @relation("UserAuditActor", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("user_audit_logs")
}

// ========================================
// 제품 카테고리
// ========================================

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  iconUrl     String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("SubCategories")
  products    Product[]
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

// ========================================
// 제품
// ========================================

model Product {
  id              String         @id @default(cuid())
  modelName       String         @unique
  name            String
  slug            String         @unique
  description     String?
  summary         String?
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  manufacturer    String         @default("LVS")
  origin          String         @default("대한민국")
  images          ProductImage[]
  specs           ProductSpec[]
  files           ProductFile[]
  colorOptions    String[]       @default([])
  voltageOptions  String[]       @default([])
  isNew           Boolean        @default(false)
  isFeatured      Boolean        @default(false)
  isActive        Boolean        @default(true)
  order           Int            @default(0)
  viewCount       Int            @default(0)
  relatedProducts String[]       @default([])
  seriesData      Json?
  productOptions  Json?
  viewLogs        ProductViewLog[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("products")
}

// ========================================
// 제품 이미지
// ========================================

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  isMain    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("product_images")
}

// ========================================
// 제품 스펙
// ========================================

model ProductSpec {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  value     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("product_specs")
}

// ========================================
// 제품 파일 (PDF, DWG)
// ========================================

model ProductFile {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  type      FileType
  url       String
  size      Int
  createdAt DateTime @default(now())

  @@map("product_files")
}

enum FileType {
  PDF
  DWG
  IMAGE
  OTHER
}

// ========================================
// 홈페이지 슬라이더
// ========================================

model Slider {
  id             String   @id @default(cuid())
  type           String   @default("TEXT_IMAGE") // TEXT_IMAGE | FULL_IMAGE
  title          String
  description    String?
  imageUrl       String
  mobileImageUrl String?  // 통이미지 모바일용 (null이면 PC 이미지 사용)
  link           String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("sliders")
}

// ========================================
// 공지사항
// ========================================

model Notice {
  id        String       @id @default(cuid())
  title     String
  content   String
  category  NoticeType   @default(NOTICE)
  isActive  Boolean      @default(true)
  isPinned  Boolean      @default(false)
  viewCount Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("notices")
}

enum NoticeType {
  NOTICE
  TECH_GUIDE
  DOWNLOAD
}

// ========================================
// 온라인 상담실 (문의사항)
// ========================================

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  title     String
  content   String
  reply     String?
  status    InquiryStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("inquiries")
}

enum InquiryStatus {
  PENDING
  ANSWERED
  CLOSED
}

// ========================================
// 카탈로그 신청
// ========================================

model CatalogRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  address   String
  message   String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("catalog_requests")
}

enum RequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

// ========================================
// 파트너사
// ========================================

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  website   String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partners")
}

// ========================================
// 회사 정보
// ========================================

model CompanyInfo {
  id             String   @id @default(cuid())
  name           String   @default("(주)엘브이에스")
  ceo            String   @default("김태화")
  businessNumber String   @default("131-86-14914")
  phone          String   @default("032-461-1800")
  fax            String   @default("032-461-1001")
  email          String?
  address        String   @default("인천광역시 연수구 송도미래로 30 B동 801~803호")
  workingHours   String   @default("평일 09:00~18:00")
  lunchTime      String   @default("12:00~13:00")
  closedDays     String   @default("일요일, 공휴일")
  updatedAt      DateTime @updatedAt

  @@map("company_info")
}

// ========================================
// 페이지 방문 추적
// ========================================

model PageView {
  id         String   @id @default(cuid())
  path       String
  sessionId  String
  userAgent  String?
  deviceType String   @default("desktop")
  browser    String?
  os         String?
  referrer   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([sessionId])
  @@index([deviceType, createdAt])
  @@map("page_views")
}

// ========================================
// 일별 집계 통계
// ========================================

model DailyStat {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  totalViews     Int      @default(0)
  uniqueVisitors Int      @default(0)
  desktopViews   Int      @default(0)
  mobileViews    Int      @default(0)
  tabletViews    Int      @default(0)
  topPages       Json?
  topReferrers   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
  @@map("daily_stats")
}

// ========================================
// 제품 조회 로그
// ========================================

model ProductViewLog {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sessionId  String
  deviceType String?  @default("desktop")
  createdAt  DateTime @default(now())

  @@index([productId, createdAt])
  @@index([createdAt])
  @@map("product_view_logs")
}

// ========================================
// 레이어 팝업
// ========================================

enum PopupPosition {
  CENTER
  TOP_LEFT
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_RIGHT
}

model LayerPopup {
  id             String        @id @default(cuid())
  title          String
  imageUrl       String?
  mobileImageUrl String?
  link           String?
  linkTarget     String        @default("_self")
  position       PopupPosition @default(CENTER)
  width          Int           @default(500)
  height         Int           @default(500)
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean       @default(true)
  order          Int           @default(0)
  templateId     String?
  templateData   Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("layer_popups")
}

// ========================================
// 네비게이션 메뉴 관리
// ========================================

model MenuItem {
  id        String     @id @default(cuid())
  label     String
  url       String
  type      String     @default("link")
  parentId  String?
  parent    MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuHierarchy")
  order     Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("menu_items")
}
